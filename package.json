{
  "name": "opmodel",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "test": "bunx --bun vitest run",
    "test:watch": "bunx --bun vitest",
    "web:build": "bun run --filter @opmodel/web build",
    "web:dev": "bun run --filter @opmodel/web dev",
    "build:hodom-v2": "bun run scripts/build-hodom-v2.ts",
    "build:hodom-hsc-v0": "bun run scripts/build-hodom-hsc-v0.ts",
    "build:ev-ams": "bun run scripts/build-ev-ams.ts",
    "build:fixtures": "bun run build:hodom-v2 && bun run build:hodom-hsc-v0 && bun run build:ev-ams"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "vitest": "^4.0.18"
  }
}
