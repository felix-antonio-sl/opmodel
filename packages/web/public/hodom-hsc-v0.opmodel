  "requirements": [
    {"description":"DS 1/2022 Art. 15: patología aguda o crónica reagudizada, clínicamente estable","id":"req-01","name":"Condición clínica estable","req_id":"R-01","target":"obj-paciente"},
    {"description":"DS 1/2022 Art. 1: indicación médica + plan terapéutico + término determinado","id":"req-02","name":"Indicación médica","req_id":"R-02","target":"obj-derivacion"},
    {"description":"DS 1/2022 Art. 15: condiciones sanitarias mínimas, servicios básicos, telefonía, radio cobertura","id":"req-03","name":"Evaluación sociosanitaria domicilio","req_id":"R-03","target":"obj-domicilio"},
    {"description":"Ley 20.584: consentimiento informado escrito obligatorio","id":"req-04","name":"Consentimiento firmado","req_id":"R-04","target":"obj-consentimiento"},
